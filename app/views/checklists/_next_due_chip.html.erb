<%# The "next checklist due" chip. Wrapper is always present (even when there's no
    due) so the live-sync can add OR clear it without a reload. Locals: issue. %>
<span id="checklist-next-due-wrap"><%
  if issue.checklist_due_date
    overdue = issue.checklist_due_date < Date.today %>
  <span class="checklist-next-due<%= ' overdue' if overdue %>"
        title="<%= l(:label_checklist_next_due, date: format_date(issue.checklist_due_date)) %>"><%=
    sprite_icon('time', l(:label_checklist_next_due, date: format_date(issue.checklist_due_date)), icon_only: true)
  %> <%= format_date(issue.checklist_due_date) %></span>
<% end %></span>
