<%# Renders a single checklist item row.
    Locals: item, can_done (bool), can_manage (bool). %>
<% if item.section? %>
  <li class="checklist-item checklist-section"
      id="checklist-item-<%= item.id %>"
      data-id="<%= item.id %>">
    <% if can_manage %>
      <span class="checklist-handle" aria-label="<%= l(:label_checklist_drag_to_reorder) %>">&#8942;</span>
    <% end %>
    <span class="checklist-section-label"><%= item.subject %></span>
    <% if can_manage %>
      <span class="checklist-item-actions">
        <a href="#"
           class="checklist-edit"
           aria-label="<%= l(:label_checklist_edit_item) %>"
           data-url="<%= issue_checklist_item_path(@issue, item) %>">&#9998;</a>
        <%= link_to sprite_icon('del', l(:button_delete), icon_only: true),
                    issue_checklist_item_path(@issue, item),
                    method: :delete,
                    remote: true,
                    class: 'checklist-delete',
                    'aria-label': l(:button_delete) %>
      </span>
    <% end %>
  </li>
<% elsif item.converted? %>
  <%# Converted (locked) row — the item's truth now lives in the child issue.
      Done-state mirrors the subtask (closed => done). No checkbox/edit/delete. %>
  <li class="checklist-item checklist-converted <%= 'is-done' if item.effective_done? %>"
      id="checklist-item-<%= item.id %>"
      data-id="<%= item.id %>">
    <span class="checklist-converted-icon" aria-hidden="true">&#8626;</span>
    <span class="checklist-item-text"><%= item.subject %></span>
    <span class="checklist-item-meta checklist-converted-meta">
      <span class="checklist-converted-link">&rarr; <%= link_to_issue(item.converted_issue, subject: false) %></span>
      <span class="checklist-converted-status"><%= item.converted_issue.status.name %></span>
    </span>
  </li>
<% else %>
  <li class="checklist-item <%= 'is-done' if item.done? %> <%= 'checklist-expandable' if can_manage %>"
      id="checklist-item-<%= item.id %>"
      data-id="<%= item.id %>">

    <% if can_manage %>
      <span class="checklist-handle" aria-label="<%= l(:label_checklist_drag_to_reorder) %>">&#8942;</span>
    <% end %>

    <%= check_box_tag "checklist_item[is_done]",
                      "1",
                      item.done?,
                      class: 'checklist-checkbox',
                      disabled: !can_done,
                      data: {
                        url:    done_issue_checklist_item_path(@issue, item),
                        method: :patch
                      } %>

    <span class="checklist-item-text"><%= item.subject %></span><%
    %><% if item.mandatory? %><span class="checklist-mandatory-flag" title="<%= l(:label_checklist_required) %>">*</span><% end %>

    <%# Meta line: assignee / due date / completion audit %>
    <% if item.assignee || item.due_date || (item.done? && item.completed_at) %>
      <span class="checklist-item-meta">
        <% if item.assignee %>
          <span class="checklist-assignee">@<%= item.assignee.name %></span>
        <% end %>
        <% if item.due_date %>
          <% overdue = item.due_date < Date.today && !item.done? %>
          <span class="checklist-due<%= ' overdue' if overdue %>"><%= format_date(item.due_date) %></span>
        <% end %>
        <% if item.done? && item.completed_at %>
          <span class="checklist-completed-meta"
                title="<%= l(:label_checklist_completed_by,
                              user: item.completed_by&.name,
                              date: format_time(item.completed_at)) %>">&#10003;</span>
        <% end %>
      </span>
    <% end %>

    <% if can_manage %>
      <span class="checklist-item-actions">
        <% if !item.done? && @issue.checklist_convert_allowed? %>
          <%= link_to sprite_icon('chevrons-right', l(:button_quick_convert_to_subtask), icon_only: true),
                      convert_quick_issue_checklist_item_path(@issue, item),
                      method: :post,
                      remote: true,
                      class: 'checklist-quick-convert',
                      title: l(:button_quick_convert_to_subtask),
                      'aria-label': l(:button_quick_convert_to_subtask) %>
          <%= link_to sprite_icon('arrow-right', l(:button_convert_to_subtask), icon_only: true),
                      convert_issue_checklist_item_path(@issue, item),
                      class: 'checklist-convert',
                      title: l(:button_convert_to_subtask),
                      'aria-label': l(:button_convert_to_subtask) %>
        <% end %>
        <button type="button"
                class="checklist-expand"
                aria-expanded="false"
                aria-label="<%= l(:label_checklist_item_details) %>"><%= sprite_icon('angle-right', l(:label_checklist_item_details), icon_only: true) %></button>
        <a href="#"
           class="checklist-edit"
           aria-label="<%= l(:label_checklist_edit_item) %>"
           data-url="<%= issue_checklist_item_path(@issue, item) %>">&#9998;</a>
        <%= link_to sprite_icon('del', l(:button_delete), icon_only: true),
                    issue_checklist_item_path(@issue, item),
                    method: :delete,
                    remote: true,
                    class: 'checklist-delete',
                    'aria-label': l(:button_delete) %>
      </span>

      <%# Detail panel — expandable, starts hidden %>
      <div class="checklist-item-details"
           style="display:none"
           data-url="<%= issue_checklist_item_path(@issue, item) %>">

        <label>
          <%= l(:field_assigned_to) %>
          <select class="checklist-detail-assignee" name="checklist_item[assignee_id]">
            <option value=""></option>
            <% @issue.assignable_users.each do |u| %>
              <option value="<%= u.id %>"<%= ' selected' if item.assignee_id == u.id %>><%= u.name %></option>
            <% end %>
          </select>
        </label>

        <label>
          <%= l(:field_due_date) %>
          <input type="date"
                 class="checklist-detail-due"
                 name="checklist_item[due_date]"
                 value="<%= item.due_date %>">
        </label>

        <label>
          <input type="checkbox"
                 class="checklist-detail-mandatory"
                 name="checklist_item[is_mandatory]"
                 value="1"
                 <%= 'checked' if item.mandatory? %>>
          <%= l(:field_is_mandatory) %>
        </label>

        <button type="button" class="checklist-detail-save checklist-add-btn"><%= l(:button_save) %></button>
        <button type="button" class="checklist-detail-cancel"><%= l(:button_cancel) %></button>
      </div>
    <% end %>
  </li>
<% end %>
