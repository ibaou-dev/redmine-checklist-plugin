                    id: 'settings_save_log' %>
  <label for="settings_save_log"><%= l(:setting_save_log) %></label>
</p>
<p>
  <%= hidden_field_tag 'settings[enforce_mandatory]', '0', id: nil %>
  <%= check_box_tag 'settings[enforce_mandatory]', '1',
                    ['true', '1', true].include?(settings['enforce_mandatory']),
                    id: 'settings_enforce_mandatory' %>
  <label for="settings_enforce_mandatory"><%= l(:setting_enforce_mandatory) %></label>
</p>
<p>
  <%= hidden_field_tag 'settings[allow_convert_parent_closed]', '0', id: nil %>
  <%= check_box_tag 'settings[allow_convert_parent_closed]', '1',
                    ['true', '1', true].include?(settings['allow_convert_parent_closed']),
                    id: 'settings_allow_convert_parent_closed' %>
  <label for="settings_allow_convert_parent_closed"><%= l(:setting_allow_convert_parent_closed) %></label>
</p>
<p>
  <label for="settings_enforce_statuses"><%= l(:setting_enforce_statuses) %></label><br>
  <input type="hidden" name="settings[enforce_statuses][]" value="">
  <%= select_tag 'settings[enforce_statuses][]',
                 options_from_collection_for_select(
                   IssueStatus.sorted,
                   :id,
                   :name,
                   Array(settings['enforce_statuses']).map(&:to_s)
                 ),
                 multiple: true,
                 size: 6,
                 id: 'settings_enforce_statuses' %>
</p>
<p>
  <%= hidden_field_tag 'settings[notify_on_assignment]', '0', id: nil %>
  <%= check_box_tag 'settings[notify_on_assignment]', '1',
                    ['true', '1', true].include?(settings['notify_on_assignment']),
                    id: 'settings_notify_on_assignment' %>
  <label for="settings_notify_on_assignment"><%= l(:setting_notify_on_assignment) %></label>
</p>
<p>
  <label for="settings_webhook_url"><%= l(:setting_webhook_url) %></label><br>
  <%= text_field_tag 'settings[webhook_url]', settings['webhook_url'],
                     id: 'settings_webhook_url', size: 60 %>
</p>
<p>
  <%= hidden_field_tag 'settings[include_checklist_assignee]', '0', id: nil %>
