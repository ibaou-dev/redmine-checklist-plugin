// destroy.js.erb — remove deleted row, refresh progress
(function() {
  var li = document.getElementById('checklist-item-<%= @checklist_item.id %>');
  if (li) { li.remove(); }

  // Replace progress wrapper
  var wrap = document.getElementById('checklist-progress-<%= @issue.id %>');
  if (wrap) {
    var tmp = document.createElement('div');
    tmp.innerHTML = <%= raw render('checklists/checklist_progress', issue: @issue).to_json %>;
    wrap.replaceWith(tmp.firstElementChild);
  }
})();

// Refresh the issue History tab in place (see _history_sync.js.erb)
<%= render 'history_sync' %>
