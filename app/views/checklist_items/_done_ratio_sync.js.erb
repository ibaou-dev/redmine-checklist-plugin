<%#
  Refreshes Redmine's core "% Done" field on the issue show page in place after a
  checklist mutation, so it updates without a full page reload — but ONLY when the
  plugin actually drives done_ratio (Affect issue done ratio on + issue-field mode
  + the issue has a checklist). Otherwise the core value is untouched.

  The done_ratio is recomputed via update_all in the controller, so @issue in
  memory is stale — read it fresh from the DB here. The show page renders the
  field as `div.attribute.progress > div.value` (label + progress_bar + .percent).
%>
<% if ChecklistItem.affects_done_ratio? %>
<% fresh_ratio = Issue.where(id: @issue.id).pick(:done_ratio).to_i %>
(function() {
  var cell = document.querySelector('.attribute.progress .value');
  if (cell) {
    cell.innerHTML = <%= raw progress_bar(fresh_ratio, legend: "#{fresh_ratio}%").to_json %>;
  }
})();
<% end %>
